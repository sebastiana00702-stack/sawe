# WHOOP API credentials (Phase 7).
#
# Copy this file to `.env` and fill in the values, OR just run the
# one-time bootstrap which writes them for you:
#
#     python -m src.ingest.auth_setup
#
# CLIENT_ID / CLIENT_SECRET come from your app at https://developer.whoop.com
# REFRESH_TOKEN is issued by the OAuth flow (auth_setup handles this).
# `.env` is gitignored — never commit real secrets.

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REFRESH_TOKEN=

# Optional: redirect URI registered for your WHOOP app (auth_setup only).
# Must match the WHOOP developer portal exactly. Defaults to:
# WHOOP_REDIRECT_URI=http://localhost:8080/callback

# Optional: single-athlete runner profile for GET /me/today. All have
# sensible defaults (intermediate / health / 30 / M / 25 mpw / 10 mi).
# SAWE_TIER=intermediate
# SAWE_GOAL=health
# SAWE_AGE=30
# SAWE_SEX=M
# SAWE_CURRENT_MPW=25
# SAWE_LONGEST_RECENT_RUN_MI=10
# SAWE_HRMAX_MEASURED=
# SAWE_VDOT=
# SAWE_TARGET_RACE_DATE=
